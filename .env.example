# Web (dev proxy only)
VITE_API_BASE_URL=/api
WEB_PORT=5174

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
PORT=3001
HOST=0.0.0.0

# Production single-container mode (Docker / VPS)
